# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` — it is gitignored.

# ---- Clerk Authentication ----
# Get these from https://dashboard.clerk.com (your app -> API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk sign-in / sign-up routes (keep as-is unless you change the paths)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# JWT issuer domain shown in Clerk dashboard -> JWT Templates -> convex
# Used by Convex to verify Clerk tokens (see convex/auth.config.ts)
CLERK_JWT_ISSUER_DOMAIN=https://your-subdomain.clerk.accounts.dev

# ---- Convex ----
# Populated automatically when you run `npx convex dev` the first time.
# Committing a placeholder here just documents the variables.
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment-name.convex.site

# ---- Google Gemini ----
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-gemini-api-key
